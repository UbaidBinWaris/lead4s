generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model JobApplication {
  id          Int      @id @default(autoincrement())
  fullName    String   @map("full_name")
  email       String
  phone       String?
  position    String
  resumePath  String   @map("resume_path")
  coverLetter String   @map("cover_letter")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("job_applications")
}

model CaseStudy {
  id           Int      @id @default(autoincrement())
  slug         String   @unique
  title        String
  vertical     String
  summary      String   @default("")
  heroLabel    String   @map("hero_label") @default("Case Study")
  heroTitle    String   @map("hero_title") @default("")
  heroIntro    String   @map("hero_intro") @default("")
  challenge    String
  solution     String
  results      String[]
  kpiLabel     String   @map("kpi_label")
  kpiValue     String   @map("kpi_value")
  isPublished  Boolean  @default(true) @map("is_published")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  sections     CaseStudySection[]

  @@map("case_studies")
}

model CaseStudySection {
  id           Int       @id @default(autoincrement())
  caseStudyId  Int       @map("case_study_id")
  sectionLabel String?   @map("section_label")
  title        String
  markdown     String
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  caseStudy    CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)

  @@map("case_study_sections")
}

model Blog {
  id         String   @id @default(uuid())
  title      String
  slug       String   @unique
  excerpt    String
  content    String   // markdown content
  coverImage String?
  author     String   @default("Admin")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("blogs")
}

model Industry {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  description  String?
  content      Json     // structured sections array
  coverImage   String?
  isPublished  Boolean  @default(true) @map("is_published")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("industries")
}
